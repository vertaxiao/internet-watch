        .section {
            display: none;
            padding: 20px 40px;
        }
        .section.active {
            display: block;
        }
        
        /* All sections - consistent spacing */
        .section .cybernews-header,
        .section .stats-grid,
        .section .table-container {
            margin-bottom: 30px;
        }
        
        .section .cybernews-header h3 {
            margin-bottom: 15px;
        }
        
        .section .refresh-btn,
        .section .last-update {
            margin-top: 20px;
        }
